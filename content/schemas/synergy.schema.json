{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SynergyDefinition",
  "type": "object",
  "required": ["id", "abilities", "anti", "effect", "hint", "fieldNotes"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "abilities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 2,
      "maxItems": 2
    },
    "anti": {
      "type": "boolean"
    },
    "effect": {
      "type": "object",
      "required": ["type", "value", "appliesAfter"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["none", "bonus_damage", "apply_status", "damage_propagation", "guaranteed_crit", "empowered_ranged", "healing_debuff"]
        },
        "value": {
          "type": "integer"
        },
        "appliesAfter": {
          "type": "string",
          "enum": ["first_ability", "second_ability", "round_end"]
        }
      }
    },
    "hint": {
      "type": "string",
      "minLength": 1
    },
    "fieldNotes": {
      "type": "object",
      "required": ["discoveredBy"],
      "properties": {
        "discoveredBy": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
