{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://the-reach.game/schemas/faction.json",
  "title": "Faction Definition",
  "type": "object",
  "required": ["id", "name", "shortName", "contact", "vendorName", "identity", "colorPrimary", "starterRep", "repThresholds", "vendorStock", "missions"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z_]+$" },
    "name": { "type": "string", "minLength": 1 },
    "shortName": { "type": "string", "minLength": 1 },
    "contact": {
      "type": "object",
      "required": ["id", "name", "portrait"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z_]+$" },
        "name": { "type": "string", "minLength": 1 },
        "portrait": { "type": "string", "minLength": 1 }
      }
    },
    "vendorName": { "type": "string", "minLength": 1 },
    "identity": { "type": "string", "minLength": 1 },
    "colorPrimary": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
    "starterRep": { "type": "integer", "minimum": -100, "maximum": 100 },
    "repThresholds": {
      "type": "object",
      "required": ["vendorAccess", "exclusiveRecruit", "patronOffice"],
      "properties": {
        "vendorAccess": { "type": "integer", "minimum": -100, "maximum": 100 },
        "exclusiveRecruit": { "type": "integer", "minimum": -100, "maximum": 100 },
        "patronOffice": { "type": "integer", "minimum": -100, "maximum": 100 }
      }
    },
    "vendorStock": {
      "type": "array",
      "minItems": 6,
      "maxItems": 12,
      "items": {
        "type": "object",
        "required": ["itemId", "name", "price", "quantity"],
        "properties": {
          "itemId": { "type": "string", "pattern": "^[a-z_]+$" },
          "name": { "type": "string", "minLength": 1 },
          "price": { "type": "integer", "minimum": 0 },
          "quantity": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "missions": {
      "type": "array",
      "minItems": 2,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "minLevel", "rewards", "repReward"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z_0-9-]+$" },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "minLevel": { "type": "integer", "minimum": 1 },
          "rewards": {
            "type": "array",
            "items": { "type": "string" }
          },
          "repReward": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
